  "meta": {
    "description": "Deterministic IPA->Arabic mapping for the Peshitta corpus.",
    "tiers": [
      "scholarly",
      "pretty",
      "vocalized",
      "unvocalized"
    ],
    "note": "transliterate_ar.py is authoritative; this file mirrors its hard-coded tables. Scholarly/Pretty are byte-identical to the English Peshitta transducer.",
    "author": "Shin"
  },
  "unicode": {
    "emphatic_marker": "ˤ",
    "length_mark": "ː",
    "alaph": "ʔ",
    "ayin": "ʕ",
    "hyphen": "-",
    "harakat": {
      "fatha": "َ",
      "kasra": "ِ",
      "damma": "ُ",
      "sukun": "ْ",
      "shadda": "ّ"
    },
    "matres": {
      "alif": "ا",
      "alif_madda": "آ",
      "waw": "و",
      "ya": "ي"
    },
    "bidi_isolates": {
      "RLI": "⁧",
      "PDI": "⁩"
    }
  },
  "segmentation": [
    "Split on ASCII space ' ' only; spaces are preserved verbatim.",
    "Within each token, left-to-right longest match:",
    "  1. consonant + \\u02E4 (ˤ) -> emphatic segment (2 chars)",
    "  2. vowel (a ɑ e i o u) + \\u02D0 (ː) -> long-vowel segment (2 chars)",
    "  3. otherwise single char"
  ],
